generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  image             String?
  roomNumber        String?
  personalId        String?   // מספר אישי
  phone             String?   // טלפון
  team              Int?      // צוות (14-17)
  birthDate         String?   // תאריך לידה
  foodPreference    String?   // העדפות אוכל
  allergies         String?   // אלרגיות
  medicalExemptions String?   // פטורים רפואיים
  otherExemptions   String?   // פטורים נוספים
  role              String    @default("user") // "user", "admin", "commander"
  roleTitle         String?   // תפקיד מפקד, e.g. "קהדית פלוגתית"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  bookings          Booking[]
  messages          Message[]
  assignedMessages  MessageAssignee[]
  attendances       Attendance[]
  commanderPosts    CommanderPost[]
  formLinks         FormLink[] @relation("formLinks")
  formSubmissions   FormSubmission[] @relation("formSubmissions")
  materials         ProfessionalMaterial[] @relation("materials")
  materialReads     MaterialRead[] @relation("materialReads")
  aktualiaEntries   AktualiaEntry[] @relation("aktualiaEntries")
  scheduleAssignees ScheduleAssignee[] @relation("scheduleAssignees")
  taskFormats       TaskFormat[] @relation("taskFormats")
  pushSubscriptions PushSubscription[]
  issuesCreated     Issue[]        @relation("issueCreator")
  issuesAssigned    IssueAssignee[] @relation("issueAssignees")
  issueComments     IssueComment[] @relation("issueComments")
  surveysCreated    Survey[]       @relation("surveyCreator")
  surveyResponses   SurveyResponse[] @relation("surveyResponses")
  weeklyVotesCast   WeeklyVote[]   @relation("weeklyVoter")
  weeklyVotesReceived WeeklyVote[] @relation("weeklyNominee")
  scheduleNotes     ScheduleNote[] @relation("scheduleNotes")
  tasks             Task[]         @relation("userTasks")
  taskResponses     TaskResponse[] @relation("taskResponses")
  dailyQuotes       DailyQuote[]   @relation("dailyQuotes")
  dutyAssignments   DutyAssignment[] @relation("dutyAssignments")
  dutyAppeals       DutyAppeal[]     @relation("dutyAppeals")
  dutySuggested     DutyAppeal[]     @relation("dutySuggested")
  simSessions       SimSession[]     @relation("simSessions")
}

model Machine {
  id        String    @id @default(uuid())
  name      String
  type      String    // "washer" or "dryer"
  status    String    @default("available")
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  machineId String
  date      String
  timeSlot  String
  status    String   @default("active")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  machine   Machine  @relation(fields: [machineId], references: [id])

  @@unique([machineId, date, timeSlot])
}

model Message {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageData String?  // base64 image data
  authorId  String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  assignees MessageAssignee[]
}

model MessageAssignee {
  id        String  @id @default(uuid())
  messageId String
  userId    String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model AttendanceSession {
  id        String   @id @default(uuid())
  name      String
  date      String
  createdBy String   // user id of who created (אוהד)
  createdAt DateTime @default(now())

  @@unique([name, date])
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  date      String
  session   String   // custom session name
  present   Boolean  @default(false)
  markedBy  String?  // who marked attendance
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date, session])
}

model CommanderPost {
  id          String   @id @default(uuid())
  authorId    String
  type        String   // "message", "task", "reminder", "image"
  title       String
  content     String
  imageUrl    String?
  pinned      Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id])
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   // "task", "deadline", "reminder", "weekly", "daily"
  startDate   DateTime
  endDate     DateTime?
  dueDate     DateTime? // תאריך גמר ביצוע
  allDay      Boolean  @default(false)
  priority    String   @default("normal") // "low", "normal", "high", "urgent"
  recurring   Boolean  @default(false)
  rrule       String?  // recurrence rule if recurring
  status      String   @default("open") // "open", "done"
  userId      String?  // null = global admin task, set = personal task
  createdAt   DateTime @default(now())
  user        User?    @relation("userTasks", fields: [userId], references: [id])
  responses   TaskResponse[]
}

model TaskResponse {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("taskResponses", fields: [userId], references: [id])

  @@index([taskId])
}

model FormLink {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  category    String   @default("general") // "general", "personnel", "operations", "training", "logistics"
  deadline    String?  // deadline date string YYYY-MM-DD
  recurring   Boolean  @default(false) // resets submissions daily
  reminderTime String? // HH:MM — auto-remind at this time daily (e.g. "20:00")
  authorId    String
  createdAt   DateTime @default(now())
  author      User     @relation("formLinks", fields: [authorId], references: [id])
  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  userId    String
  date      String?  // YYYY-MM-DD for recurring forms (null = one-time)
  createdAt DateTime @default(now())
  form      FormLink @relation(fields: [formId], references: [id], onDelete: Cascade)
  user      User     @relation("formSubmissions", fields: [userId], references: [id])

  @@unique([formId, userId, date])
}

model ProfessionalMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   @default("general") // "general", "weapons", "navigation", "first-aid", "procedures", "other"
  tags        String?  // JSON array of custom tag strings, e.g. '["ל\"ע","נהלים"]'
  fileData    String   // base64 encoded file
  fileName    String
  fileType    String   // mime type
  authorId    String
  createdAt   DateTime @default(now())
  author      User     @relation("materials", fields: [authorId], references: [id])
  reads       MaterialRead[]
}

model MaterialRead {
  id         String   @id @default(uuid())
  materialId String
  userId     String
  createdAt  DateTime @default(now())
  material   ProfessionalMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user       User     @relation("materialReads", fields: [userId], references: [id])

  @@unique([materialId, userId])
}

model TaskFormat {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   @default("general") // "general", "guard", "operations", "training", "logistics", "other"
  fileData    String   // base64 encoded file
  fileName    String
  fileType    String   // mime type
  authorId    String
  createdAt   DateTime @default(now())
  author      User     @relation("taskFormats", fields: [authorId], references: [id])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AktualiaEntry {
  id         String   @id @default(uuid())
  roomNumber String
  subject    String
  date       String   // YYYY-MM-DD, resets daily
  userId     String
  createdAt  DateTime @default(now())
  user       User     @relation("aktualiaEntries", fields: [userId], references: [id])

  @@unique([roomNumber, date])
  @@unique([userId, date])
}

model ScheduleEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  allDay      Boolean  @default(false)
  target      String   @default("all") // "all", "team-14", "team-15", "team-16", "team-17"
  type        String   @default("general") // "general", "meal", "training", "ceremony", "personal", "free"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignees   ScheduleAssignee[]
}

model ScheduleAssignee {
  id        String        @id @default(uuid())
  eventId   String
  userId    String
  event     ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User          @relation("scheduleAssignees", fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model Issue {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("new") // "new", "open", "urgent", "closed"
  location    String?  // מיקום
  imageUrl    String?  // תמונה של הפורמט/תקלה
  companion   String?  // מלווה שם
  companionPhone String? // מלווה טלפון
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation("issueCreator", fields: [createdById], references: [id])
  assignees   IssueAssignee[]
  comments    IssueComment[]
}

model IssueAssignee {
  id      String @id @default(uuid())
  issueId String
  userId  String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user    User   @relation("issueAssignees", fields: [userId], references: [id])

  @@unique([issueId, userId])
}

model IssueComment {
  id        String   @id @default(uuid())
  issueId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation("issueComments", fields: [userId], references: [id])
}

// ─── Team Surveys (סקרים) ───

model Survey {
  id          String   @id @default(uuid())
  title       String
  description String?
  team        Int      // which team (14-17) — only that team sees it
  type        String   // "yes_no", "single", "multi"
  options     String?  // JSON array of options for single/multi, null for yes_no
  status      String   @default("active") // "active", "closed"
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("surveyCreator", fields: [createdById], references: [id])
  responses   SurveyResponse[]
}

model SurveyResponse {
  id        String   @id @default(uuid())
  surveyId  String
  userId    String
  answer    String   // JSON: "yes"/"no" for yes_no, "[0,2]" for multi, "1" for single
  createdAt DateTime @default(now())
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User     @relation("surveyResponses", fields: [userId], references: [id])

  @@unique([surveyId, userId])
}

// ─── Person of the Week (איש של השבוע) ───

model WeeklyVote {
  id         String   @id @default(uuid())
  week       String   // ISO week string e.g. "2026-W11"
  voterId    String
  nomineeId  String
  reason     String?
  createdAt  DateTime @default(now())
  voter      User     @relation("weeklyVoter", fields: [voterId], references: [id])
  nominee    User     @relation("weeklyNominee", fields: [nomineeId], references: [id])

  @@unique([week, voterId]) // one vote per user per week
}

// ─── Personal / Team Schedule Notes (הערות אישיות ללו"ז) ───

model ScheduleNote {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        String   // YYYY-MM-DD
  startTime   String?  // HH:MM (optional — can be timeless)
  endTime     String?  // HH:MM
  visibility  String   @default("personal") // "personal" or "team"
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation("scheduleNotes", fields: [userId], references: [id])
}

// ─── Daily Quote (משפט היומי) ───

model DailyQuote {
  id        String   @id @default(uuid())
  text      String
  date      String   @unique // YYYY-MM-DD — one quote per day
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation("dailyQuotes", fields: [userId], references: [id])
}

// ─── Guard Duty Tables (שיבוץ שמירות / עב"ס) ───

model DutyTable {
  id          String   @id @default(uuid())
  title       String   // e.g. "שיבוץ לשמירות", "עב"ס בהד"י"
  date        String   // YYYY-MM-DD
  type        String   // "guard" or "obs" (שמירות / עב"ס)
  // JSON array of role column names, e.g. ["שג רכוב קדמי","שג רכוב אחורי","פט",...]
  roles       String
  // JSON array of time slot strings, e.g. ["08:00-12:00","12:00-16:00",...]
  timeSlots   String
  // Optional JSON metadata (e.g. squads/חולייות)
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignments DutyAssignment[]
  appeals     DutyAppeal[]

  @@unique([date, type])
}

model DutyAssignment {
  id          String   @id @default(uuid())
  tableId     String
  table       DutyTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("dutyAssignments", fields: [userId], references: [id])
  timeSlot    String   // e.g. "08:00-12:00" or "08:30-11:30"
  role        String   // e.g. "שג רכוב קדמי", "בונקר", slot number for עב"ס
  note        String?  // e.g. sub-hours "17:00-20:00" when different from main timeSlot
  createdAt   DateTime @default(now())

  @@unique([tableId, timeSlot, role, userId])
}

model DutyAppeal {
  id              String   @id @default(uuid())
  tableId         String
  table           DutyTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  assignmentId    String
  userId          String
  user            User     @relation("dutyAppeals", fields: [userId], references: [id])
  reason          String
  suggestedUserId String?
  suggestedUser   User?    @relation("dutySuggested", fields: [suggestedUserId], references: [id])
  status          String   @default("pending") // "pending", "approved", "rejected"
  createdAt       DateTime @default(now())
}

// ─── סימולטור פיקודי (Commander Simulator) ───

model SimScenario {
  id                  String   @id @default(uuid())
  title               String
  description         String?
  conflictCharacter   String   // תפקיד הדמות (e.g. "חיילת מתלוננת")
  machineName         String   // שם הדמות (e.g. "רונה")
  relationship        String   // הקשר בין הדמות למשתמש
  servicenature       String   // רקע הסימולציה
  objective           String   // מטרת הסימולציה
  machineMotivation   String   // מוטיבציות הדמות
  keypoints           String   // נקודות מפתח
  difficulty          Int      @default(5) // 1-10
  soldierGender       String   @default("female") // "male" or "female"
  gradeRequirements   String?  // JSON: requirements for passing (e.g. '{"pass": "עובר"}')
  skills              String?  // JSON array of skills to evaluate
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  sessions            SimSession[]
}

model SimSession {
  id            String   @id @default(uuid())
  scenarioId    String
  scenario      SimScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation("simSessions", fields: [userId], references: [id])
  mode          String   @default("chat") // "chat" or "voice"
  status        String   @default("active") // "active", "completed", "abandoned"
  messages      String?  // JSON array of chat messages
  score         Int?     // 0-100
  feedback      String?  // AI-generated feedback text
  skillsRating  String?  // JSON: skill ratings
  grade         String?  // "עובר" / "לא עובר"
  startedAt     DateTime @default(now())
  completedAt   DateTime?
}
